{
  "name": "sidequesters-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend foundation for the SideQuesters mobile app",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "db:setup": "node scripts/setup-sqlite.mjs",
    "prisma:seed": "node scripts/setup-sqlite.mjs --seed-only",
    "prisma:seed-mocks": "tsx prisma/seed_mocks.ts",
    "setup:dev": "npm run prisma:generate && npm run db:setup"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "prisma": "^6.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
